// ===================== Events =====================

// Room events - each as a separate function

@UTSJS.keepAlive
export function onRoomStateChanged(options : OnRoomStateChangedOptions) : void {
  const handler = RtcEventProxy.getOrCreateRoomHandler(options.roomId)
  handler.onRoomStateChangedCallback = (roomId : string, uid : string, state : number, extraInfo : string) => {
    options.callback({
      roomId: roomId, uid: uid, state: state as number, extraInfo: extraInfo
    })
  }
  RtcRoomManager.setRoomEventHandler(options.roomId, handler)
}

@UTSJS.keepAlive
export function onUserJoined(options : OnUserJoinedOptions) : void {
  const handler = RtcEventProxy.getOrCreateRoomHandler(options.roomId)
  handler.onUserJoinedCallback = (roomId : string, uid : string) => {
    options.callback({
      roomId: roomId, uid: uid, elapsed: 0
    })
  }
  RtcRoomManager.setRoomEventHandler(options.roomId, handler)
}

@UTSJS.keepAlive
export function onUserLeave(options : OnUserLeaveOptions) : void {
  const handler = RtcEventProxy.getOrCreateRoomHandler(options.roomId)
  handler.onUserLeaveCallback = (roomId : string, uid : string, reason : number) => {
    options.callback({
      roomId: roomId, uid: uid, reason: reason as number
    })
  }
  RtcRoomManager.setRoomEventHandler(options.roomId, handler)
}

@UTSJS.keepAlive
export function onUserPublishStream(options : OnUserPublishStreamOptions) : void {
  const handler = RtcEventProxy.getOrCreateRoomHandler(options.roomId)
  handler.onUserPublishStreamCallback = (roomId : string, uid : string, mediaType : string) => {
    options.callback({
      roomId: roomId, uid: uid, streamIndex: mediaType as AnyRtcStreamIndex
    })
  }
  RtcRoomManager.setRoomEventHandler(options.roomId, handler)
}

@UTSJS.keepAlive
export function onUserUnpublishStream(options : OnUserUnpublishStreamOptions) : void {
  const handler = RtcEventProxy.getOrCreateRoomHandler(options.roomId)
  handler.onUserUnpublishStreamCallback = (roomId : string, uid : string, mediaType : string) => {
    options.callback({
      roomId: roomId, uid: uid, streamIndex: mediaType as AnyRtcStreamIndex
    })
  }
  RtcRoomManager.setRoomEventHandler(options.roomId, handler)
}

@UTSJS.keepAlive
export function onFirstRemoteVideoFrameDecoded(options : OnFirstRemoteVideoFrameDecodedOptions) : void {
  if (eventProxy == null) return
  eventProxy!.onFirstRemoteVideoFrameDecodedCallback = (uid : string, streamIndex : string, width : number, height : number) => {
    options.callback({
      roomId: options.roomId, uid: uid, streamIndex: streamIndex as AnyRtcStreamIndex,
      width: width as number, height: height as number, elapsed: 0
    })
  }
}

@UTSJS.keepAlive
export function onRoomStats(options : OnRoomStatsOptions) : void {
  const handler = RtcEventProxy.getOrCreateRoomHandler(options.roomId)
  handler.onRoomStatsCallback = (roomId : string, userCount : number, duration : number) => {
    options.callback({
      roomId: roomId, userCount: userCount as number, duration: duration as number
    })
  }
  RtcRoomManager.setRoomEventHandler(options.roomId, handler)
}

export function offRoomEvent(options : RemoveRoomEventListenerOptions) : void {
  RtcEventProxy.removeRoomHandler(options.roomId)
}

// Engine events

@UTSJS.keepAlive
export function onEngineWarning(options : OnEngineWarningOptions) : void {
  if (eventProxy == null) return
  eventProxy!.onWarningCallback = (code : number, message : string) => {
    options.callback({ code: code as number, message: message })
  }
}

@UTSJS.keepAlive
export function onEngineError(options : OnEngineErrorOptions) : void {
  if (eventProxy == null) return
  eventProxy!.onErrorCallback = (code : number, message : string) => {
    options.callback({ code: code as number, message: message })
  }
}

export function offEngineEvent(options : RemoveEngineEventListenerOptions) : void {
  eventProxy?.clearEngineCallbacks()
}
