import View from 'android.view.View'
import Manifest from 'android.Manifest'
import PackageManager from 'android.content.pm.PackageManager'
import Build from 'android.os.Build'

// Singleton event proxy instance
let eventProxy : RtcEventProxy | null = null
// Lifecycle callback references for cleanup
let pauseCallback : (() => void) | null = null
let resumeCallback : (() => void) | null = null

// ===================== Helpers =====================

function checkPermission(permission : string) : boolean {
  if (Build.VERSION.SDK_INT < 23) return true
  const context = UTSAndroid.getAppContext()!
  return context.checkSelfPermission(permission) == PackageManager.PERMISSION_GRANTED
}

function ensureEngine(failCallback : ((err : AnyRtcFailImpl) => void) | null, completeCallback : (() => void) | null) : boolean {
  if (!RtcEngineManager.isInitialized()) {
    const err = new AnyRtcFailImpl(9010001)
    failCallback?.(err)
    completeCallback?.()
    return false
  }
  return true
}

// ===================== Engine =====================

export function createEngine(options : CreateEngineOptions) : void {
  if (RtcEngineManager.isInitialized()) {
    const err = new AnyRtcFailImpl(9010002)
    options.fail?.(err)
    options.complete?.()
    return
  }

  try {
    const context = UTSAndroid.getAppContext()!
    const proxy = new RtcEventProxy()
    const engine = RtcEngineManager.createEngine(context, options.appId, proxy)
    if (engine != null) {
      eventProxy = proxy

      pauseCallback = () => {
        RtcEngineManager.onAppPause()
      }
      resumeCallback = () => {
        RtcEngineManager.onAppResume()
      }
      UTSAndroid.onAppActivityPause(pauseCallback!)
      UTSAndroid.onAppActivityResume(resumeCallback!)

      options.success?.({})
    } else {
      const err = new AnyRtcFailImpl(9010011)
      options.fail?.(err)
    }
  } catch (e : Exception) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function destroyEngine(options : DestroyEngineOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    if (pauseCallback != null) {
      UTSAndroid.offAppActivityPause(pauseCallback!)
      pauseCallback = null
    }
    if (resumeCallback != null) {
      UTSAndroid.offAppActivityResume(resumeCallback!)
      resumeCallback = null
    }
    RtcEffectsManager.dispose()
    eventProxy?.clearEngineCallbacks()
    RtcEventProxy.clearAllRoomHandlers()
    RtcEngineManager.destroyEngine()
    eventProxy = null
    options.success?.({})
  } catch (e : Exception) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

// ===================== Room =====================

export function createRoom(options : CreateRoomOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    const room = RtcRoomManager.createRoom(options.roomId)
    if (room != null) {
      options.success?.({})
    } else {
      const err = new AnyRtcFailImpl(9010011)
      options.fail?.(err)
    }
  } catch (e : Exception) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function joinRoom(options : JoinRoomOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  if (!RtcRoomManager.hasRoom(options.roomId)) {
    const err = new AnyRtcFailImpl(9010003)
    options.fail?.(err)
    options.complete?.()
    return
  }

  try {
    const channelProfile = RtcTypeConverter.toChannelProfile(options.roomProfile ?? 'communication')
    const autoPublish = options.isAutoPublish ?? true
    const result = RtcRoomManager.joinRoom(
      options.roomId,
      options.token,
      options.userId,
      options.userName,
      channelProfile,
      autoPublish,
      autoPublish,
      options.isAutoSubscribeAudio ?? true,
      options.isAutoSubscribeVideo ?? true
    )
    if (result == 0) {
      options.success?.({})
    } else {
      const err = new AnyRtcFailImpl(9010011)
      options.fail?.(err)
    }
  } catch (e : Exception) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function leaveRoom(options : LeaveRoomOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  if (!RtcRoomManager.hasRoom(options.roomId)) {
    const err = new AnyRtcFailImpl(9010003)
    options.fail?.(err)
    options.complete?.()
    return
  }

  try {
    RtcRoomManager.leaveRoom(options.roomId)
    options.success?.({})
  } catch (e : Exception) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function destroyRoom(options : DestroyRoomOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    RtcEventProxy.removeRoomHandler(options.roomId)
    RtcRoomManager.destroyRoom(options.roomId)
    options.success?.({})
  } catch (e : Exception) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

