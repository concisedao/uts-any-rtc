export function setVideoEncoderConfig(options : SetVideoEncoderConfigOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    const config = new VideoEncoderConfig()
    config.width = (options.width ?? 640) as Int
    config.height = (options.height ?? 480) as Int
    config.frameRate = (options.frameRate ?? 15) as Int
    config.maxBitrate = (options.bitrate ?? -1) as Int
    RtcEngineManager.setVideoEncoderConfig(config)
    options.success?.({})
  } catch (e : Exception) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function switchCamera(options : SwitchCameraOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    const cameraId = RtcTypeConverter.toCameraId(options.facing ?? 'front')
    RtcEngineManager.switchCamera(cameraId)
    options.success?.({})
  } catch (e : Exception) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function setLocalVideoCanvas(options : SetLocalVideoCanvasOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    const streamIndex = RtcTypeConverter.toStreamIndex(options.streamIndex ?? 'main')
    if (options.view != null) {
      const canvas = new VideoCanvas()
      canvas.renderView = options.view as View
      canvas.renderMode = RtcTypeConverter.toRenderMode(options.renderMode ?? 'hidden')
      RtcEngineManager.setLocalVideoCanvas(streamIndex, canvas)
    } else {
      RtcEngineManager.setLocalVideoCanvas(streamIndex, null)
    }
    options.success?.({})
  } catch (e : Exception) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function setRemoteVideoCanvas(options : SetRemoteVideoCanvasOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    const streamIndex = RtcTypeConverter.toStreamIndex(options.streamIndex ?? 'main')
    if (options.view != null) {
      const canvas = new VideoCanvas()
      canvas.renderView = options.view as View
      canvas.renderMode = RtcTypeConverter.toRenderMode(options.renderMode ?? 'hidden')
      RtcEngineManager.setRemoteVideoCanvas(options.roomId, options.uid, streamIndex, canvas)
    } else {
      RtcEngineManager.setRemoteVideoCanvas(options.roomId, options.uid, streamIndex, null)
    }
    options.success?.({})
  } catch (e : Exception) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

