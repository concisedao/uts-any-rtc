import { AnyRtcFailImpl } from '../unierror.uts'

// Native framework imports
import { UIView, UIApplication } from "UIKit"
import { NSObjectProtocol } from "Foundation"
import { ByteRTCVideoCanvas, ByteRTCVideoEncoderConfig, ByteRTCMediaStreamType } from "BytePlusRTC" assert { type: "implementationOnly" }

// Singleton event proxy instance
let eventProxy : RtcEventProxy | null = null
// Notification observers for lifecycle, need cleanup on destroy
let bgObserver : NSObjectProtocol | null = null
let fgObserver : NSObjectProtocol | null = null

// ===================== Helpers =====================

function ensureEngine(failCallback : ((err : AnyRtcFailImpl) => void) | null, completeCallback : (() => void) | null) : boolean {
  if (!RtcEngineManager.shared.isInitialized()) {
    const err = new AnyRtcFailImpl(9010001)
    failCallback?.(err)
    completeCallback?.()
    return false
  }
  return true
}

// ===================== Engine =====================

export function createEngine(options : CreateEngineOptions) : void {
  if (RtcEngineManager.shared.isInitialized()) {
    const err = new AnyRtcFailImpl(9010002)
    options.fail?.(err)
    options.complete?.()
    return
  }

  try {
    const proxy = new RtcEventProxy()
    const engine = RtcEngineManager.shared.createEngine(appId = options.appId, delegate = proxy)
    if (engine != null) {
      eventProxy = proxy

      // Register lifecycle observers
      const nc = NotificationCenter.default
      bgObserver = nc.addObserver(
        forName = UIApplication.didEnterBackgroundNotification,
        object = null,
        queue = null,
        using = (notification : Notification) => {
          RtcEngineManager.shared.onAppPause()
        }
      )
      fgObserver = nc.addObserver(
        forName = UIApplication.didBecomeActiveNotification,
        object = null,
        queue = null,
        using = (notification : Notification) => {
          RtcEngineManager.shared.onAppResume()
        }
      )

      options.success?.({})
    } else {
      const err = new AnyRtcFailImpl(9010011)
      options.fail?.(err)
    }
  } catch (e) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function destroyEngine(options : DestroyEngineOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    // 移除生命周期观察者，防止内存泄漏
    const nc = NotificationCenter.default
    if (bgObserver != null) {
      nc.removeObserver(bgObserver!)
      bgObserver = null
    }
    if (fgObserver != null) {
      nc.removeObserver(fgObserver!)
      fgObserver = null
    }
    // 安全释放美颜资源（未初始化时为空操作）
    RtcEffectsManager.shared.dispose()
    eventProxy?.clearEngineCallbacks()
    RtcRoomEventProxy.clearAll()
    RtcEngineManager.shared.destroyEngine()
    eventProxy = null
    options.success?.({})
  } catch (e) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

// ===================== Room =====================

export function createRoom(options : CreateRoomOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    const room = RtcRoomManager.shared.createRoom(roomId = options.roomId)
    if (room != null) {
      options.success?.({})
    } else {
      const err = new AnyRtcFailImpl(9010011)
      options.fail?.(err)
    }
  } catch (e) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function joinRoom(options : JoinRoomOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  if (!RtcRoomManager.shared.hasRoom(roomId = options.roomId)) {
    const err = new AnyRtcFailImpl(9010003)
    options.fail?.(err)
    options.complete?.()
    return
  }

  try {
    const channelProfile = RtcTypeConverter.toChannelProfile(options.roomProfile ?? 'communication')
    const result = RtcRoomManager.shared.joinRoom(
      roomId = options.roomId,
      token = options.token,
      userId = options.userId,
      userName = options.userName,
      channelProfile = channelProfile,
      isAutoPublish = options.isAutoPublish ?? true,
      isAutoSubscribeAudio = options.isAutoSubscribeAudio ?? true,
      isAutoSubscribeVideo = options.isAutoSubscribeVideo ?? true
    )
    if (result == 0) {
      options.success?.({})
    } else {
      const err = new AnyRtcFailImpl(9010011)
      options.fail?.(err)
    }
  } catch (e) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function leaveRoom(options : LeaveRoomOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  if (!RtcRoomManager.shared.hasRoom(roomId = options.roomId)) {
    const err = new AnyRtcFailImpl(9010003)
    options.fail?.(err)
    options.complete?.()
    return
  }

  try {
    RtcRoomManager.shared.leaveRoom(roomId = options.roomId)
    options.success?.({})
  } catch (e) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function destroyRoom(options : DestroyRoomOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    RtcRoomEventProxy.remove(roomId = options.roomId)
    RtcRoomManager.shared.destroyRoom(roomId = options.roomId)
    options.success?.({})
  } catch (e) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

