export function setVideoEncoderConfig(options : SetVideoEncoderConfigOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    const config = new ByteRTCVideoEncoderConfig()
    config.width = (options.width ?? 640) as Int
    config.height = (options.height ?? 480) as Int
    config.frameRate = (options.frameRate ?? 15) as Int
    config.maxBitrate = (options.bitrate ?? -1) as Int
    RtcEngineManager.shared.setVideoEncoderConfig(config)
    options.success?.({})
  } catch (e) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function switchCamera(options : SwitchCameraOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    const cameraId = RtcTypeConverter.toCameraId(options.facing ?? 'front')
    RtcEngineManager.shared.switchCamera(cameraId)
    options.success?.({})
  } catch (e) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function setLocalVideoCanvas(options : SetLocalVideoCanvasOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    const streamIndex = RtcTypeConverter.toStreamIndex(options.streamIndex ?? 'main')
    if (options.view != null) {
      const canvas = new ByteRTCVideoCanvas()
      canvas.view = options.view as UIView
      canvas.renderMode = RtcTypeConverter.toRenderMode(options.renderMode ?? 'hidden')
      // canvas.mirrorType not supported in SDK 3.60.1
      RtcEngineManager.shared.setLocalVideoCanvas(streamIndex = streamIndex, canvas = canvas)
    } else {
      RtcEngineManager.shared.setLocalVideoCanvas(streamIndex = streamIndex, canvas = null)
    }
    options.success?.({})
  } catch (e) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

export function setRemoteVideoCanvas(options : SetRemoteVideoCanvasOptions) : void {
  if (!ensureEngine(options.fail, options.complete)) return

  try {
    const streamIndex = RtcTypeConverter.toStreamIndex(options.streamIndex ?? 'main')
    if (options.view != null) {
      const canvas = new ByteRTCVideoCanvas()
      canvas.view = options.view as UIView
      canvas.renderMode = RtcTypeConverter.toRenderMode(options.renderMode ?? 'hidden')
      // canvas.mirrorType not supported in SDK 3.60.1
      RtcEngineManager.shared.setRemoteVideoCanvas(roomId = options.roomId, uid = options.uid, streamIndex = streamIndex, canvas = canvas)
    } else {
      RtcEngineManager.shared.setRemoteVideoCanvas(roomId = options.roomId, uid = options.uid, streamIndex = streamIndex, canvas = null)
    }
    options.success?.({})
  } catch (e) {
    const err = new AnyRtcFailImpl(9010011)
    options.fail?.(err)
  }
  options.complete?.()
}

