// ===================== Events =====================


// Room events - each as a separate function

@UTSJS.keepAlive
export function onRoomStateChanged(options : OnRoomStateChangedOptions) : void {
  const proxy = RtcRoomEventProxy.getOrCreate(roomId = options.roomId)
  proxy.onRoomStateChangedCallback = (roomId : string, uid : string, state : number, extraInfo : string) => {
    options.callback({
      roomId: roomId, uid: uid, state: state as number, extraInfo: extraInfo
    })
  }
  RtcRoomManager.shared.setRoomDelegate(roomId = options.roomId, delegate = proxy)
}

@UTSJS.keepAlive
export function onUserJoined(options : OnUserJoinedOptions) : void {
  const proxy = RtcRoomEventProxy.getOrCreate(roomId = options.roomId)
  proxy.onUserJoinedCallback = (roomId : string, uid : string, elapsed : number) => {
    options.callback({
      roomId: roomId, uid: uid, elapsed: elapsed as number
    })
  }
  RtcRoomManager.shared.setRoomDelegate(roomId = options.roomId, delegate = proxy)
}

@UTSJS.keepAlive
export function onUserLeave(options : OnUserLeaveOptions) : void {
  const proxy = RtcRoomEventProxy.getOrCreate(roomId = options.roomId)
  proxy.onUserLeaveCallback = (roomId : string, uid : string, reason : number) => {
    options.callback({
      roomId: roomId, uid: uid, reason: reason as number
    })
  }
  RtcRoomManager.shared.setRoomDelegate(roomId = options.roomId, delegate = proxy)
}

@UTSJS.keepAlive
export function onUserPublishStream(options : OnUserPublishStreamOptions) : void {
  const proxy = RtcRoomEventProxy.getOrCreate(roomId = options.roomId)
  proxy.onUserPublishStreamCallback = (roomId : string, uid : string, streamIndex : string) => {
    options.callback({
      roomId: roomId, uid: uid, streamIndex: streamIndex as AnyRtcStreamIndex
    })
