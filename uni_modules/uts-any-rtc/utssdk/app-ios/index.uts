@UTSJS.keepAlive
export function onFirstRemoteVideoFrameDecoded(options : OnFirstRemoteVideoFrameDecodedOptions) : void {
  const proxy = RtcRoomEventProxy.getOrCreate(roomId = options.roomId)
  proxy.onFirstRemoteVideoFrameDecodedCallback = (roomId : string, uid : string, streamIndex : string, width : number, height : number, elapsed : number) => {
    options.callback({
      roomId: roomId, uid: uid, streamIndex: streamIndex as AnyRtcStreamIndex,
      width: width as number, height: height as number, elapsed: elapsed as number
    })
  }
  RtcRoomManager.shared.setRoomDelegate(roomId = options.roomId, delegate = proxy)
}

@UTSJS.keepAlive
export function onRoomStats(options : OnRoomStatsOptions) : void {
  const proxy = RtcRoomEventProxy.getOrCreate(roomId = options.roomId)
  proxy.onRoomStatsCallback = (roomId : string, userCount : number, duration : number) => {
    options.callback({
      roomId: roomId, userCount: userCount as number, duration: duration as number
    })
  }
  RtcRoomManager.shared.setRoomDelegate(roomId = options.roomId, delegate = proxy)
}

export function offRoomEvent(options : RemoveRoomEventListenerOptions) : void {
  RtcRoomEventProxy.remove(roomId = options.roomId)
}

// Engine events

@UTSJS.keepAlive
export function onEngineWarning(options : OnEngineWarningOptions) : void {
  if (eventProxy == null) return
  eventProxy!.onWarningCallback = (code : number, message : string) => {
    options.callback({ code: code as number, message: message })
  }
}

@UTSJS.keepAlive
export function onEngineError(options : OnEngineErrorOptions) : void {
  if (eventProxy == null) return
  eventProxy!.onErrorCallback = (code : number, message : string) => {
    options.callback({ code: code as number, message: message })
  }
}

export function offEngineEvent(options : RemoveEngineEventListenerOptions) : void {
  eventProxy?.clearEngineCallbacks()
}
